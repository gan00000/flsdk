<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <RelativeLayout
        android:layout_width="300dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:background="@color/c_sdk_bg"
        >

        <TextView
            android:id="@+id/autoLoginTips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lines="1"
            android:text="@string/py_login"
            android:textColor="@color/white_c"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_centerHorizontal="true"

            android:layout_below="@id/autoLoginTips"
            android:gravity="center"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/dialog_loading"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:indeterminateDrawable="@drawable/gama_progress_dialog_rotate" />

            <TextView
                android:id="@+id/dialog_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="5dp"
                android:text="等待中..."
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/white_c" />
        </LinearLayout>

        <Button
            android:id="@+id/autoLoginSwitch"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="20dp"
            android:layout_centerHorizontal="true"
            android:layout_width="200dp"
            android:layout_height="30dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/sdk_btn3_corners25_bg"
            android:gravity="center"
            android:text="@string/py_confire"
            android:textColor="@android:color/white"
            android:textSize="14sp" />


    </RelativeLayout>

</RelativeLayout>