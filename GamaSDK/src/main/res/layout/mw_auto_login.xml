<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/c_sdk_bg"
    >

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        >

        <TextView
            android:id="@+id/autoLoginTips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lines="1"
            android:text="@string/py_login"
            android:textColor="@color/white_c"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/dialog_loading"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:indeterminateDrawable="@drawable/gama_progress_dialog_rotate" />

            <TextView
                android:id="@+id/dialog_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/text_waiting"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/white_c" />
        </LinearLayout>

        <Button
            android:id="@+id/autoLoginSwitch"
            android:layout_centerHorizontal="true"
            android:layout_width="266dp"
            android:layout_height="40dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/sdk_btn3_corners20_bg"
            android:gravity="center"
            android:text="@string/py_confire"
            android:textColor="@android:color/white"
            android:textSize="17sp" />


    </LinearLayout>

</RelativeLayout>