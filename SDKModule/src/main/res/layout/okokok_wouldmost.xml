<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="272dp"
    android:layout_height="wrap_content"
    android:layout_centerInParent="true"
    android:background="@color/mcolor_riskeer_tripsliveia">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_centerInParent="true"

        >
        <ImageView
            android:id="@+id/mId_himer_bad"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginTop="12dp"
            android:src="@mipmap/nend_update_account_bg" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:textSize="13sp"
            android:text="@string/mstr_pratia_laugh"
            android:textColor="@color/mcolor_tag_tetrice"
            android:id="@+id/mId_helpern_nemorant"

            />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:layout_centerInParent="true"
        android:layout_marginBottom="17dp"
        android:layout_marginTop="18dp"
        android:gravity="center"
        >


        <Button
            android:id="@+id/mId_often_person"
            android:layout_width="108dp"
            android:layout_height="match_parent"
            android:background="@drawable/okokok_largoon"
            android:gravity="center"
            android:text="@string/mstr_topion_jungon"
            android:textColor="@android:color/white"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/mId_odform_plicarian"
            android:layout_width="108dp"
            android:layout_height="match_parent"
            android:background="@drawable/okokok_dorming"
            android:layout_marginStart="22dp"
            android:gravity="center"
            android:text="@string/mstr_mindo_pietaire"
            android:textColor="@android:color/white"
            android:textSize="12sp"/>

        </LinearLayout>
    </LinearLayout>


</RelativeLayout>