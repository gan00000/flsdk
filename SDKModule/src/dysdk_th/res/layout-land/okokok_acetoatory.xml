<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="498dp"
        android:layout_height="288dp"
        android:layout_centerInParent="true"
        android:background="@drawable/okokok_chrysanyone"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/okokok_lactmachine"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/mstr_opoteran_glassress"
                android:textColor="@color/mcolor_tag_tetrice"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"

                android:id="@+id/mId_clavresponsibilityic_man"

                />

            <ImageView
                android:layout_width="35dp"
                android:layout_height="14dp"
                android:layout_centerVertical="true"
                android:visibility="gone"
                android:layout_toStartOf="@+id/tv_notice_title"
                android:src="@mipmap/okokok_septision"
                android:layout_marginEnd="17dp"/>

            <ImageView
                android:layout_width="35dp"
                android:layout_height="14dp"
                android:visibility="gone"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@+id/tv_notice_title"
                android:src="@mipmap/okokok_mneosity"
                android:layout_marginStart="17dp"/>


            <ImageView
                android:id="@+id/mId_audance_fundise"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:src="@mipmap/okokok_tactline" />

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/okokok_predette"
            android:orientation="vertical">

            <com.ldy.sdk.SWebViewLayout
                android:id="@+id/mId_face_artistivity"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </RelativeLayout>

    </LinearLayout>


</RelativeLayout>